{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "dataCollectionRuleName": {
      "type": "string",
      "defaultValue": "dcr-credential-expiry",
      "metadata": {
        "description": "Name of the Data Collection Rule"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region (must match the Log Analytics workspace region)"
      }
    },
    "workspaceResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Log Analytics workspace"
      }
    },
    "dataCollectionEndpointResourceId": {
      "type": "string",
      "metadata": {
        "description": "Full resource ID of the Data Collection Endpoint"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Insights/dataCollectionRules",
      "apiVersion": "2023-03-11",
      "name": "[parameters('dataCollectionRuleName')]",
      "location": "[parameters('location')]",
      "tags": {
        "purpose": "credential-expiry-monitoring",
        "createdBy": "arm-template"
      },
      "properties": {
        "dataCollectionEndpointId": "[parameters('dataCollectionEndpointResourceId')]",
        "streamDeclarations": {
          "Custom-AppCredentialExpiry_CL": {
            "columns": [
              {
                "name": "AppDisplayName",
                "type": "string"
              },
              {
                "name": "AppId",
                "type": "string"
              },
              {
                "name": "ObjectId",
                "type": "string"
              },
              {
                "name": "CredentialType",
                "type": "string"
              },
              {
                "name": "CredentialId",
                "type": "string"
              },
              {
                "name": "CredentialDisplayName",
                "type": "string"
              },
              {
                "name": "ExpirationDate",
                "type": "datetime"
              },
              {
                "name": "DaysUntilExpiry",
                "type": "int"
              },
              {
                "name": "CheckTimestamp",
                "type": "datetime"
              }
            ]
          }
        },
        "destinations": {
          "logAnalytics": [
            {
              "workspaceResourceId": "[parameters('workspaceResourceId')]",
              "name": "logAnalyticsWorkspace"
            }
          ]
        },
        "dataFlows": [
          {
            "streams": [
              "Custom-AppCredentialExpiry_CL"
            ],
            "destinations": [
              "logAnalyticsWorkspace"
            ],
            "transformKql": "source | extend TimeGenerated = now()",
            "outputStream": "Custom-AppCredentialExpiry_CL"
          }
        ]
      }
    }
  ],
  "outputs": {
    "dataCollectionRuleResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName'))]"
    },
    "dataCollectionRuleImmutableId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Insights/dataCollectionRules', parameters('dataCollectionRuleName')), '2023-03-11').immutableId]"
    }
  }
}